rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == "admin";
    }

    function isPhysician() {
      return signedIn() &&
        (request.auth.token.role == "physician" || isAdmin());
    }

    function ownsScopedRecord(data) {
      return signedIn() && (
        data.userId == request.auth.uid ||
        data.patientId == request.auth.uid ||
        data.physicianId == request.auth.uid ||
        data.ownerId == request.auth.uid ||
        data.recipientId == request.auth.uid ||
        data.assignedTo == request.auth.uid
      );
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();

      match /{document=**} {
        allow read, write: if signedIn() &&
          (request.auth.uid == userId || isAdmin());
      }
    }

    match /patients/{patientId} {
      allow read: if signedIn() && (request.auth.uid == patientId || isPhysician());
      allow create, update: if signedIn() &&
        (request.auth.uid == patientId || isPhysician());
      allow delete: if isAdmin();

      match /{document=**} {
        allow read, write: if signedIn() &&
          (request.auth.uid == patientId || isPhysician());
      }
    }

    match /physicians/{physicianId} {
      allow read: if signedIn() && (request.auth.uid == physicianId || isAdmin());
      allow create, update: if signedIn() &&
        (request.auth.uid == physicianId || isAdmin());
      allow delete: if isAdmin();

      match /{document=**} {
        allow read, write: if signedIn() &&
          (request.auth.uid == physicianId || isAdmin());
      }
    }

    match /{collection}/{documentId} {
      allow read: if signedIn() &&
        (isPhysician() || ownsScopedRecord(resource.data));

      allow create: if signedIn() &&
        (isPhysician() || ownsScopedRecord(request.resource.data));

      allow update: if signedIn() &&
        (isPhysician() ||
          (ownsScopedRecord(resource.data) &&
            ownsScopedRecord(request.resource.data)));

      allow delete: if signedIn() &&
        (isPhysician() || ownsScopedRecord(resource.data));
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

# =============================================================================
# Application
# =============================================================================

NODE_ENV=development
NEXT_PUBLIC_APP_NAME=ChroniSync
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Firebase Web App Configuration
# =============================================================================

NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# =============================================================================
# Firebase Admin SDK (Server Only)
# Use the service account details from your Firebase project.
# =============================================================================

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Optional if you want to override the web storage bucket value on the server.
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# =============================================================================
# Google Gemini API
# =============================================================================

GEMINI_API_KEY=your_gemini_api_key

# Optional
GEMINI_MODEL=gemini-2.5-flash

# =============================================================================
# File Upload
# =============================================================================

MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=application/pdf,image/jpeg,image/png,image/webp

# =============================================================================
# Rules Engine
# =============================================================================

BP_SYSTOLIC_THRESHOLD=140
BP_DIASTOLIC_THRESHOLD=90
GLUCOSE_THRESHOLD=180
MEDICATION_MISSED_DAYS=2

# =============================================================================
# Session
# =============================================================================

SESSION_TIMEOUT_MINUTES=30

# =============================================================================
# Feature Flags
# =============================================================================

ENABLE_AI_EXTRACTION=true
ENABLE_AI_SUMMARIZATION=true
ENABLE_NOTIFICATIONS=false
ENABLE_ANALYTICS=false

# =============================================================================
# Logging
# =============================================================================

LOG_LEVEL=info

# =============================================================================
# Development
# =============================================================================

NEXT_PUBLIC_ENABLE_MOCK_DATA=true
NEXT_PUBLIC_SHOW_DEVTOOLS=true

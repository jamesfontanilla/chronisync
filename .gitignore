```gitignore
# =============================================================================
# Dependencies
# =============================================================================
node_modules/

# pnpm
.pnpm-store/
.pnpm-debug.log*

# npm
npm-debug.log*

# yarn
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
yarn-error.log*

# =============================================================================
# Next.js
# =============================================================================
.next/
out/
build/

# =============================================================================
# Production
# =============================================================================
dist/

# =============================================================================
# Environment Variables
# =============================================================================
.env
.env.local
.env.development.local
.env.production.local
.env.test.local
!.env.example

# =============================================================================
# Firebase
# =============================================================================
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# Firebase Emulator Data
*.overall_export_metadata
firebase-export/

# =============================================================================
# Logs
# =============================================================================
logs/
*.log

# =============================================================================
# TypeScript
# =============================================================================
*.tsbuildinfo

# =============================================================================
# Coverage
# =============================================================================
coverage/
.nyc_output/

# =============================================================================
# Testing
# =============================================================================
playwright-report/
test-results/

# =============================================================================
# Cache
# =============================================================================
.cache/
.parcel-cache/
.turbo/
.vercel/
.eslintcache

# =============================================================================
# IDEs
# =============================================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

.idea/

# =============================================================================
# Operating System Files
# =============================================================================
.DS_Store
Thumbs.db
Desktop.ini

# =============================================================================
# Temporary Files
# =============================================================================
tmp/
temp/
*.tmp
*.swp
*.swo

# =============================================================================
# Local Certificates
# =============================================================================
*.pem
*.key
*.crt

# =============================================================================
# Miscellaneous
# =============================================================================
*.seed
*.pid
*.pid.lock

# =============================================================================
# Generated Documentation
# =============================================================================
docs/generated/

# =============================================================================
# AI Outputs (Optional)
# =============================================================================
ai-output/
gemini-cache/

# =============================================================================
# Local Uploads
# =============================================================================
uploads/
storage/

# =============================================================================
# Vercel
# =============================================================================
.vercel

# =============================================================================
# Misc
# =============================================================================
*.orig
*.rej
```
